# Copy this file to .env and fill in real values.
# Never commit .env — it's already in the repo's .gitignore.

# Port the Express server listens on
PORT=4000

# From Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Comma-separated list of origins allowed to call this API.
# During local dev with VS Code's Live Server, that's port 5500
# (it can serve from either host depending on your settings).
CORS_ORIGIN=http://127.0.0.1:5500,http://localhost:5500

# From resend.com → API Keys. Welcome/enrolment-confirmation/
# motivational emails are skipped (logged, not sent) if this is unset.
RESEND_API_KEY=your-resend-api-key

# Without a verified sending domain on Resend, you can only send FROM
# this sandbox address, and only TO the email you signed up to Resend
# with — fine for testing, but you'll want to verify your own domain
# on Resend before this reaches real users.
EMAIL_FROM=ResearchBridge Consulting <onboarding@resend.dev>
